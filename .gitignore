# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/

# Environment files
# Commit .env.example files, ignore everything else that has real secrets
.env
.env.local
.env.*.local
!.env.example
!backend/.env.example
!frontend/.env.example

# Real env files with secrets — never commit these
backend/.env
backend/.env.development
backend/.env.production
backend/.env.staging
frontend/.env
frontend/.env.development
frontend/.env.production
frontend/.env.staging

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Editor
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Docker
.docker/

# Uploads (local dev)
uploads/

# SSL certs
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key

# Misc
.cache/
.temp/
tmp/
