# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Required) ──────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/marketplace
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/marketplace
MONGODB_URI=mongodb://localhost:27017/marketplace
MONGODB_TEST_URI=mongodb://localhost:27017/marketplace_test

# ─── Redis (Required) ─────────────────────────────────────────────────────────
# Local:  redis://localhost:6379
# Cloud:  redis://user:pass@host:port
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT — must be 32+ characters (Required) ──────────────────────────────────
JWT_SECRET=generate-with-node-crypto-randomBytes-32
JWT_REFRESH_SECRET=another-different-32-char-string-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3000

# ─── Cloudinary (Required for image uploads) ──────────────────────────────────
# Get from: cloudinary.com -> Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email / SMTP (Required for verification emails) ─────────────────────────
# Gmail: enable 2FA, then create App Password at myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=noreply@yourstore.com
EMAIL_FROM_NAME=Your Store

# ─── AI / OpenRouter (Optional — for AI assistant & smart search) ─────────────
# Get free key at: openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Manual Payment (edit bank details in src/config/payment.ts) ──────────────
# No API keys needed. Edit backend/src/config/payment.ts to set your bank details.

# ─── Admin Seed Account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=ChangeThisPassword123
ADMIN_FIRST_NAME=Store
ADMIN_LAST_NAME=Admin

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ─── Monitoring (Optional) ────────────────────────────────────────────────────
SENTRY_DSN=
